<div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
  <h3 style="color: #166534; margin: 0;">🛡️ Secure View Compiled Successfully</h3>
  <button hx-get="/ui/reset-mask" hx-target="#mask-output" style="background: #fd4d40; width: auto; padding: 6px 12px; font-size: 13px;">✕ Clear View</button>
</div>
<p style="font-size: 14px; color:#475569;">The target column was completely stripped execution-side before rendering.</p>
<div style="overflow-x: auto;">
  <div style="background: #eff6ff; border: 1px solid #bfdbfe; padding: 15px; border-radius: 8px; margin: 20px 0;">
  <h4 style="margin: 0 0 5px 0; color: #1e40af;">🔗 Secure Sharing Link Generated</h4>
  <p style="margin: 0 0 10px 0; font-size: 14px; color: #1e3a8a;">Copy this link and send it to team members who shouldn't see redacted columns. The encryption is enforced directly by our servers.</p>
  <input type="text" value="<%= shareLink %>" readonly style="background: #fff; margin: 0; max-width: 100%; font-family: monospace; cursor: pointer;" onclick="this.select(); document.execCommand('copy'); alert('Link copied to clipboard!');">
</div>
  <table>
    <thead>
      <tr>
        <% headers.forEach(header => { %>
          <th><%= header %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(row => { %>
        <tr>
          <% headers.forEach(header => { %>
            <td <% if(String(row[header]).includes('MASKED')) { %> style="color:red; background:#fff5f5; font-weight:bold;" <% } %> >
              <%= row[header] %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>