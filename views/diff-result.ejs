<div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
  <h3 style="margin: 0;">Delta Analysis Report</h3>
  <button hx-get="/ui/reset-diff" hx-target="#diff-output" style="background: #64748b; width: auto; padding: 6px 12px; font-size: 13px;">✕ Clear View</button>
</div>
<br>
<% if (diffResults.length === 0) { %>
  <p style="color: green; font-weight: bold;">✓ Verification Complete: Uploaded documents match exactly. No row updates tracked.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Row Index</th>
        <th>Field Affected</th>
        <th>Original State (v1)</th>
        <th>Updated State (v2)</th>
      </tr>
    </thead>
    <tbody>
      <% diffResults.forEach(row => { %>
        <% Object.keys(row.changes).forEach(key => { %>
          <% if(row.changes[key].status === 'modified') { %>
            <tr>
              <td><%= row.rowIndex %></td>
              <td><strong><%= key %></strong></td>
              <td style="background: #fee2e2; color: #991b1b;"><%= row.changes[key].original || '(Empty Cell)' %></td>
              <td style="background: #dcfce7; color: #166534;"><%= row.changes[key].current || '(Empty Cell)' %></td>
            </tr>
          <% } %>
        <% }) %>
      <% }) %>
    </tbody>
  </table>
<% } %>